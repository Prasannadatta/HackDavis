# Runtime environment label.
APP_ENV=development

# Python logging level.
LOG_LEVEL=INFO

# Backend host and port for local uvicorn runs.
HOST=0.0.0.0
PORT=8000

# Rule score threshold where Claude validation can start.
SOFT_THRESHOLD=30

# Rule score threshold required before final alert can fire.
HARD_THRESHOLD=70

# Minimum Claude confidence required for Claude details and final alert.
CLAUDE_CONFIDENCE_THRESHOLD=70

# Minimum seconds between Claude validation calls per session.
CLAUDE_COOLDOWN_SECONDS=15

# Set to true to use deterministic fake Claude responses for demos.
MOCK_CLAUDE=true

# Required only when MOCK_CLAUDE=false.
ANTHROPIC_API_KEY=

# Claude model used when MOCK_CLAUDE=false.
CLAUDE_MODEL=claude-3-5-sonnet-latest

# Set to true to persist sessions and reports to MongoDB Atlas.
PERSIST_TO_MONGO=false

# MongoDB Atlas connection string.
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority

# MongoDB database and collection names.
MONGODB_DB=scamshield
MONGODB_COLLECTION=call_sessions

# Twilio (REST API key + account; used for webhook validation / future API calls).
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_PHONE_NUMBER=

# Public origin Twilio can reach (https://your-ngrok-subdomain.ngrok.io — no trailing slash).
PUBLIC_BASE_URL=

# Deepgram streaming STT for Twilio Media Streams (mu-law).
DEEPGRAM_API_KEY=

# Real protected phone number to dial after Twilio starts the media stream.
GRANDMAS_REAL_NUMBER=

# Firebase Admin SDK credentials for sending FCM push alerts.
# Use the local path to your downloaded service account JSON file.
FIREBASE_SERVICE_ACCOUNT_FILE=

# ElevenLabs TTS for Academy audio routes.
ENABLE_ELEVENLABS=true
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# Optional language-specific voice overrides.
ELEVENLABS_VOICE_ID_EN=
ELEVENLABS_VOICE_ID_HI=
ELEVENLABS_VOICE_ID_ES=

# Optional Hugging Face Academy dataset import.
ACADEMY_USE_HF_DATASET=true
ACADEMY_HF_DATASET_NAME=BothBosu/scam-dialogue
ACADEMY_MAX_DATASET_SCENARIOS=80
ACADEMY_DATASET_CACHE_DIR=.cache/huggingface
ACADEMY_STORE_IMPORTED_SCENARIOS=false
